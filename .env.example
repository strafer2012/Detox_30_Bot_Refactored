# ============================================
# Detox 30 Bot - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Required
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=123456789  # Your Telegram user ID

# Database
DATABASE_PATH=detox30.db

# Optional: Sentry for error tracking (production)
SENTRY_DSN=
ENVIRONMENT=production
RELEASE=2026-05-10-v42

# Message schedule times (local user time)
MORNING_TIME=08:00
EDUCATION_TIME=14:00
EVENING_TIME=20:30

# Default timezone offset (e.g. 7 for UTC+7)
USER_TIMEZONE=7

# Scheduler check interval in minutes
CHECK_INTERVAL=1

# Closed chat link (optional)
CLOSED_CHAT_LINK=https://t.me/+6usILTSdMQIwMGU6
